---
layout: null
permalink: /api/posts.json
---
[
  {% for post in site.posts %
  }
  {
    "title": {
      { post.title | jsonify
      }
    },
    "date": {
      { post.date | date: "%B %d, %Y" | jsonify
      }
    },
    "image": {% if post.image %
    }{
      { post.image.path | default: post.image | relative_url | jsonify
      }
    }{% else %
    }null{% endif %
    },
    "url": {
      { post.url | relative_url | jsonify
      }
    },
    "excerpt": {
      { post.description | default: post.excerpt | strip_html | strip_newlines | truncate: 160 | jsonify
      }
    }
  }{% unless forloop.last %
  },
  {% endunless %
  }
  {% endfor %
  }
]
